{
  "schema_version": "1.0.0",
  "purpose": "乔木 PPT 路由、确认门和生产边界的指令遵循冒烟用例。",
  "cases": [
    {
      "id": "initial_broad_topic_default_does_not_produce",
      "prompt": "生成一个 10 页 PPT 介绍黄家驹，默认就行，不用过多搜索。",
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "broad_topic_ppt",
        "validation_profile": "plan",
        "production_authorized": false,
        "stop_before": "guided_choice_or_design_proposal",
        "required_references": ["references/guided-choice-flow.md", "references/topic-research-method.md"],
        "primary_scripts": ["scripts/prepare_deck_project.py", "scripts/topic_research.py"],
        "global_reminders": ["~/Downloads/Qiaomu PPT", "第一步资料搜索整理"],
        "check_plan_run_now": ["路线卡与最终交付门", "content_preflight.py", "top_quality_plan.py", "选择卡或默认路线门"],
        "check_plan_defer_until_final": ["PPTX 可编辑性检查"],
        "check_plan_skip_by_default": ["bootstrap.py --check"],
        "forbidden_scripts": ["scripts/produce_deck.py"]
      }
    },
    {
      "id": "after_choice_default_starts_research_not_final_render",
      "prompt": "默认，按推荐配置生成。",
      "stage": "after_choice",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "broad_topic_ppt",
        "validation_profile": "plan",
        "production_authorized": false,
        "stop_before": "guided_choice_or_design_proposal",
        "check_plan_skip_by_default": ["bootstrap.py --check"],
        "next_action_contains": ["主题研究", "方案规划", "调研包归档"],
        "global_reminders": ["~/Downloads/Qiaomu PPT", "research_dossier.md"]
      }
    },
    {
      "id": "explicit_bypass_allows_production",
      "prompt": "不用确认，直接生成最终版 PPT，主题是乔木 AI 工具年度总结，12 页，可编辑 PPTX。",
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "broad_topic_ppt",
        "validation_profile": "final",
        "production_authorized": true,
        "approval_bypass_phrase": "不用确认",
        "stop_before": "none",
        "check_plan_run_now": ["content_preflight.py", "top_quality_plan.py", "最终导出清单", "PPTX 预览缩略图"],
        "primary_scripts": ["scripts/prepare_deck_project.py", "scripts/create_deck.py"],
        "global_reminders": ["~/Downloads/Qiaomu PPT"]
      }
    },
    {
      "id": "url_to_ppt_reads_source_first",
      "prompt": "根据这个网页链接做一份演讲 slides，自动抓取文章内容和图片，最终要可编辑 PPTX。",
      "inputs": ["https://example.com/article"],
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "source_to_ppt",
        "final_delivery": "editable_pptx",
        "validation_profile": "plan",
        "production_authorized": false,
        "required_references": ["references/source-intake-method.md", "references/url-ingestion.md"],
        "primary_scripts": ["scripts/prepare_deck_project.py", "scripts/source_to_markdown.py"],
        "global_reminders": ["~/Downloads/Qiaomu PPT", "下载/提取图片"],
        "check_plan_run_now": ["来源清单"],
        "check_plan_defer_until_final": ["PPTX 可编辑性检查"],
        "required_gates": ["来源证据门"]
      }
    },
    {
      "id": "paper_route_uses_paper_intake",
      "prompt": "把这篇 Hugging Face paper 做成 PPT，先从 arXiv TeX 里提取图表。",
      "inputs": ["https://huggingface.co/papers/2606.12345"],
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "paper_to_ppt",
        "validation_profile": "plan",
        "required_references": ["references/paper-source-intake.md"],
        "primary_scripts": ["scripts/prepare_deck_project.py", "scripts/paper_to_markdown.py"],
        "global_reminders": ["~/Downloads/Qiaomu PPT"],
        "check_plan_run_now": ["论文来源可达性"],
        "production_authorized": false
      }
    },
    {
      "id": "html_deck_does_not_promise_editable_pptx",
      "prompt": "做一个网页 PPT，要 GSAP 动效和横向翻页，不需要 PPTX。",
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "html_deck",
        "final_delivery": "semantic_html_deck",
        "validation_profile": "plan",
        "required_references": ["references/html-output.md", "references/html-design-kernel.md", "references/html-motion.md"],
        "check_plan_run_now": ["HTML 最终交付确认门"],
        "check_plan_skip_by_default": ["PPTX 可编辑性检查"],
        "production_authorized": false
      }
    },
    {
      "id": "html_deck_with_no_negative_routes_to_html",
      "prompt": "做一个网页 PPT，要 GSAP 动效和横向翻页，最终交付 HTML deck。",
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "html_deck",
        "final_delivery": "semantic_html_deck",
        "validation_profile": "plan",
        "required_references": ["references/html-output.md", "references/html-design-kernel.md", "references/html-motion.md"],
        "primary_scripts": ["scripts/validate_html_deck.py"],
        "check_plan_defer_until_final": ["validate_html_deck.py"],
        "check_plan_skip_by_default": ["PPTX 可编辑性检查"],
        "production_authorized": false
      }
    },
    {
      "id": "copy_improvement_stays_planning_only",
      "prompt": "帮我把这份 PPT 的内容和文案改得更有说服力，标题要更吸引人，先不要导出。",
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "content_copy_improvement",
        "final_delivery": "planning_only",
        "validation_profile": "plan",
        "production_authorized": false,
        "stop_before": "final_export",
        "check_plan_run_now": ["文案门"],
        "check_plan_skip_by_default": ["最终 PPTX/HTML/PDF 导出"],
        "required_references": ["references/content-copy-method.md"]
      }
    },
    {
      "id": "courseware_checks_subject_boundary",
      "prompt": "帮我把这节高中数学课做成课件，含例题、课堂练习和教师备注。",
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "courseware",
        "final_delivery": "editable_pptx",
        "validation_profile": "plan",
        "required_gates": ["教学正确性门", "教师备注门"],
        "check_plan_run_now": ["学科/年级/教材边界门"],
        "production_authorized": false
      }
    },
    {
      "id": "default_aesthetic_applies_to_any_topic",
      "prompt": "生成 12 页 PPT 介绍苏轼的审美世界，用户没指定风格。",
      "stage": "initial",
      "slides": 12,
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "broad_topic_ppt",
        "validation_profile": "plan",
        "production_authorized": false,
        "required_references": ["references/ppt-aesthetic-quality-framework.md", "references/visual-character-and-style-picker.md", "references/image-text-integration-contract.md"],
        "check_plan_run_now": ["默认审美决策门", "图文融合计划门"],
        "global_reminders": ["用户未指定风格时", "图片必须和每页内容绑定"]
      }
    },
    {
      "id": "notebooklm_without_style_suggests_readable_style_options",
      "prompt": "用 NotebookLM 原生 PPT 介绍《七龙珠》，15 页，用户没有指定风格。",
      "stage": "initial",
      "slides": 15,
      "expected": {
        "is_qiaomu_ppt_task": true,
        "route": "notebooklm_native_pptx",
        "final_delivery": "notebooklm_native_pptx_plus_pdf",
        "validation_profile": "plan",
        "production_authorized": false,
        "required_references": ["references/notebooklm-native-deck.md"],
        "required_gates": ["风格提示注入门"],
        "global_reminders": ["3-5 个", "--prompt", "--format presenter"]
      }
    },
    {
      "id": "non_ppt_image_request_does_not_trigger",
      "prompt": "给我生成一张小红书封面图，不做 PPT。",
      "stage": "initial",
      "expected": {
        "is_qiaomu_ppt_task": false,
        "route": "not_qiaomu_ppt",
        "validation_profile": "none",
        "check_plan_skip_by_default": ["qiaomu-ppt 全部生产检查"],
        "production_authorized": false
      }
    }
  ]
}
