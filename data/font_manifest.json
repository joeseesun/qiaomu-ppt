{
  "schema_version": "1.0.0",
  "default_font_family": "Noto Sans CJK SC",
  "license": "SIL Open Font License 1.1",
  "license_url": "https://github.com/notofonts/noto-cjk/blob/main/LICENSE",
  "fonts": [
    {
      "family": "Noto Sans CJK SC",
      "style": "Regular",
      "filename": "NotoSansCJKsc-Regular.otf",
      "url": "https://github.com/notofonts/noto-cjk/raw/main/Sans/OTF/SimplifiedChinese/NotoSansCJKsc-Regular.otf",
      "used_for": "Chinese body text and classroom-safe readable layouts."
    },
    {
      "family": "Noto Sans CJK SC",
      "style": "Bold",
      "filename": "NotoSansCJKsc-Bold.otf",
      "url": "https://github.com/notofonts/noto-cjk/raw/main/Sans/OTF/SimplifiedChinese/NotoSansCJKsc-Bold.otf",
      "used_for": "Chinese titles, claim headlines, and emphasis."
    }
  ],
  "install": "python3 scripts/bootstrap.py --download-fonts",
  "note": "Font binaries are downloaded into assets/fonts/ and ignored by git by default."
}
