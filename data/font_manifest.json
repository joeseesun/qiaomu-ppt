      "used_for": "Code blocks, CLI examples, terminal screenshots recreated as editable text, and aligned CJK/Latin tables."
    }
  ],
  "optional_packs": [
    {
      "id": "display",
      "label": "Display title pack",
      "families": ["Smiley Sans"],
      "use_when": "A cover or chapter title needs a distinctive Chinese display voice.",
      "avoid_when": "Dense body text, classroom reading, or formal evidence pages."
    },
    {
      "id": "courseware",
      "label": "Courseware warmth pack",
      "families": ["LXGW WenKai"],
      "use_when": "The deck benefits from warmer handwriting-like Chinese without becoming casual.",
      "avoid_when": "Strict enterprise reports, dense data slides, or narrow text boxes."
    },
    {
      "id": "code",
      "label": "Code and monospace pack",
      "families": ["Sarasa Mono SC", "JetBrains Mono"],
      "use_when": "The deck contains code, terminals, configuration snippets, or CJK/Latin aligned tables.",
      "avoid_when": "Normal prose; do not use monospace as a decorative general-purpose font."
    }
