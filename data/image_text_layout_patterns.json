        "人物介绍",
        "问题解释",
        "章节正文"
      ],
      "font_size": {
        "title_pt": "40-52",
        "body_pt": "22-26"
      },
      "image_role": [
        "evidence",
        "product",
        "person"
      ],
      "rules": [
        "Left text should be one title plus no more than three bullets.",
        "Right image should use full-height crop when possible.",
        "Do not crop the subject into the edge."
      ],
      "avoid": [
        "dense paragraphs in the text half",
        "generic stock image with no proof role"
